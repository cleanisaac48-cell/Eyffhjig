# Payment Provider Selection
PAYMENT_PROVIDER=paypal  # Options: paypal | stripe | both

# PayPal (Active Now)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret
PAYPAL_WEBHOOK_SECRET=your_webhook_secret
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id

# Stripe (Ready for Later)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudflare (Video + Edge)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token_with_stream_edit_permissions
CLOUDFLARE_STREAM_KEY=your_stream_api_key

# Supabase (Database + Auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co 
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Ably (Realtime)
NEXT_PUBLIC_ABLY_API_KEY=your_ably_key
ABLY_API_KEY=your_ably_key_with_subscribe_publish

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=World TVs
ENCRYPTION_KEY=random_32_char_string_for_jwt

# Billing Configuration
BASE_FEE_KES=5000
INCLUDED_VIEWERS=500
OVERAGE_RATE_KES=10

# Optional: Analytics
SENTRY_DSN=https://...
NEXT_PUBLIC_GA_ID=G-...
